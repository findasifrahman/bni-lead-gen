{
  "name": "bni-lead-gen-suite",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/api run build && npm --workspace apps/web run build",
    "prisma:generate": "npm --workspace apps/api run prisma:generate",
    "migrate:dev": "npm --workspace apps/api run migrate:dev",
    "migrate:deploy": "npm --workspace apps/api run migrate:deploy",
    "seed": "npm --workspace apps/api run seed"
  }
}
